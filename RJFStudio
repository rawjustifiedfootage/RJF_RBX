<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RJF News</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Poppins', sans-serif;
      background: #0f0f0f;
      color: white;
      line-height: 1.6;
    }

    a {
      color: #7dd3fc;
      text-decoration: none;
    }

    header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(15,15,15,0.9);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
      padding: 20px;
    }

    .header-container {
      max-width: 1200px;
      margin: auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 15px;
      flex-wrap: wrap;
    }

    .logo {
      font-size: 2rem;
      font-weight: 700;
      background: linear-gradient(90deg, #38bdf8, #818cf8);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .search-box {
      flex: 1;
      min-width: 250px;
    }

    .search-box input {
      width: 100%;
      padding: 12px 16px;
      border-radius: 12px;
      border: none;
      background: #1a1a1a;
      color: white;
      outline: none;
      font-size: 1rem;
    }

    .hero {
      max-width: 1200px;
      margin: 40px auto;
      padding: 0 20px;
    }

    .hero-card {
      position: relative;
      border-radius: 24px;
      overflow: hidden;
      min-height: 400px;
      display: flex;
      align-items: end;
      background: #1a1a1a;
      box-shadow: 0 10px 40px rgba(0,0,0,0.4);
    }

    .hero-card img {
      position: absolute;
      width: 100%;
      height: 100%;
      object-fit: cover;
      opacity: 0.45;
    }

    .hero-content {
      position: relative;
      padding: 40px;
      z-index: 2;
    }

    .hero-content h1 {
      font-size: 3rem;
      margin-bottom: 10px;
    }

    .hero-content p {
      max-width: 700px;
      color: #d1d5db;
    }

    .news-section {
      max-width: 1200px;
      margin: auto;
      padding: 20px;
    }

    .section-title {
      font-size: 2rem;
      margin-bottom: 20px;
      font-weight: 600;
    }

    .news-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 25px;
    }

    .news-card {
      background: #171717;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.08);
      transition: 0.25s ease;
    }

    .news-card:hover {
      transform: translateY(-5px);
      border-color: rgba(125,211,252,0.4);
      box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    }

    .news-card img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      background: #222;
    }

    .news-content {
      padding: 20px;
    }

    .news-date {
      font-size: 0.85rem;
      color: #9ca3af;
      margin-bottom: 10px;
    }

    .news-content h2 {
      margin-bottom: 12px;
      font-size: 1.3rem;
    }

    .news-content p {
      color: #d1d5db;
      font-size: 0.95rem;
    }

    .tag {
      display: inline-block;
      margin-bottom: 12px;
      padding: 6px 12px;
      border-radius: 999px;
      background: rgba(56,189,248,0.15);
      color: #7dd3fc;
      font-size: 0.8rem;
      font-weight: 600;
    }

    footer {
      text-align: center;
      padding: 40px 20px;
      color: #9ca3af;
      margin-top: 40px;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .empty-message {
      display: none;
      text-align: center;
      margin-top: 30px;
      color: #9ca3af;
      font-size: 1.1rem;
    }

    @media (max-width: 768px) {
      .hero-content h1 {
        font-size: 2rem;
      }

      .hero-content {
        padding: 25px;
      }
    }
  </style>
</head>
